GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# The backend also accepts GOOGLE_GEMINI_API_KEY or GOOGLE_API_KEY if your host
# already stores the Gemini key under one of those names.

# Required only for the static GitHub Pages build.
# Point this at a deployed /api/coach endpoint, for example a Cloudflare Worker URL.
VITE_COACH_API_URL=https://your-worker.example.workers.dev/api/coach

# Optional server-side settings.
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
# COACH_ALLOWED_ORIGIN=https://your-github-username.github.io
